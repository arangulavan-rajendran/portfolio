<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Arangulavan Rajendran — Tech Lead</title>
  <meta name="description" content="Tech Lead specializing in banking systems, data repositories, and fintech. Dubai, UAE." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Castoro:ital@0;1&family=Public+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="styles.css" />
  <script>document.documentElement.classList.remove("no-js"); document.documentElement.classList.add("js");</script>
</head>
<body>
  <header class="s-header" id="top">
    <div class="s-header__inner">
      <div class="s-header__logo">
        <a href="#intro">Portfolio</a>
      </div>
      <button class="s-header__menu-toggle" type="button" aria-label="Open menu" aria-expanded="false">
        <span>Menu</span>
      </button>
      <nav class="s-header__nav" aria-label="Primary">
        <ul class="s-header__menu-links">
          <li><a href="#intro">Intro</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#works">Works</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main>
    <section class="s-intro" id="intro">
      <div class="s-intro__media" aria-hidden="true">
        <img
          class="s-intro__media-img"
          src="assets/Portfolio_home_page.jpg"
          alt=""
          width="1200"
          height="900"
          loading="eager"
          decoding="async"
        />
      </div>
      <div class="container s-intro__content">
        <div class="s-intro__text">
          <p class="s-intro__pretitle">Hello</p>
          <h1 class="s-intro__title">
            I’m Arangulavan Rajendran<br />
            a Tech Lead<br />
            based in Dubai (UAE).
          </h1>
          <div class="s-intro__btns">
            <a class="btn btn--primary" href="#about">More About Me</a>
            <a class="btn btn--stroke" href="#contact">Get In Touch</a>
          </div>
          <ul class="s-intro__social">
            <li>
              <a href="https://www.linkedin.com/in/arangulavan-rajendran-101929211/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </li>
          </ul>
          <p class="s-intro__cv">
            <a class="btn btn--stroke btn--cv" href="mailto:arangulavanraj@gmail.com?subject=Resume%20request">Request resume</a>
          </p>
        </div>
      </div>
      <div class="s-intro__scroll">
        <a href="#about">
          <span>Scroll Down</span>
          <span class="s-intro__scroll-icon" aria-hidden="true">↓</span>
        </a>
      </div>
    </section>

    <section class="s-about section-pad" id="about">
      <div class="container">
        <h2 class="s-section__title">About Me.</h2>
        <div class="s-about__lead">
          <p>
            Tech Lead with extensive experience in application development and project management, specializing in data analysis. I have successfully led the retrieval of data from the Finacle core banking system and developed a centralized data repository, enhancing regulatory compliance through automated BRF report generation.
          </p>
          <p>
            I spearheaded the design of applications for VAT automation, commercial credit systems, and risk tools, improving banking operations. Previously, I developed an instant payment system for Bank of Baroda Fiji, facilitating real-time interbank transactions. I aim to leverage technical expertise to drive innovation in financial technology solutions.
          </p>
        </div>
        <div class="s-about__blocks">
          <div class="s-about__block">
            <h3 class="s-about__block-title">Experience</h3>
            <ul class="s-about__list">
              <li><span class="s-about__co">Bornfire Innovation</span> <span class="s-about__role">Tech Lead · Dec 2023 – Present</span></li>
              <li><span class="s-about__co">Bornfire Innovation</span> <span class="s-about__role">Software Developer · May 2022 – Dec 2023</span></li>
            </ul>
          </div>
          <div class="s-about__block">
            <h3 class="s-about__block-title">Certifications</h3>
            <ul class="s-about__list s-about__list--cert">
              <li><span class="s-about__award-title">Core Java, J2EE</span> <span class="s-about__award-meta">Accord Info Matrix — Jan 2022</span></li>
              <li><span class="s-about__award-title">HTML, JS, PHP, CSS, DOM, MySQL</span> <span class="s-about__award-meta">Accord Info Matrix — Jan 2022</span></li>
            </ul>
          </div>
          <div class="s-about__block">
            <h3 class="s-about__block-title">Skills</h3>
            <ul class="s-about__list s-about__list--skills">
              <li>Java · VBA (Excel) · HTML · CSS · JavaScript</li>
              <li>MySQL · Oracle SQL · Spring Tool Suite · Git</li>
              <li>Quick learner · Teamwork · Problem solving</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="s-works section-pad" id="works">
      <div class="container">
        <h2 class="s-section__title">Selected Works.</h2>
        <p class="s-section__intro">Project highlights at Bornfire Innovation Pvt Ltd — Bank of Baroda and regional banking delivery.</p>

        <div class="works-filter" role="tablist" aria-label="Filter projects">
          <button type="button" class="works-filter__btn is-active" data-filter="all">All</button>
          <button type="button" class="works-filter__btn" data-filter="lead">Tech Lead</button>
          <button type="button" class="works-filter__btn" data-filter="dev">Developer</button>
        </div>

        <div class="folio-grid">
          <article class="folio-item" data-category="lead">
            <a class="folio-item__link" href="#contact">
              <div class="folio-item__img folio-item__img--1"></div>
              <div class="folio-item__body">
                <h3 class="folio-item__title">Finacle data &amp; BRF automation</h3>
                <p class="folio-item__tag">Core banking · Compliance</p>
                <p class="folio-item__desc">Centralized repository and automated Banking Return Form reports for regulatory compliance.</p>
                <span class="folio-item__more">Project details</span>
              </div>
            </a>
          </article>
          <article class="folio-item" data-category="lead">
            <a class="folio-item__link" href="#contact">
              <div class="folio-item__img folio-item__img--2"></div>
              <div class="folio-item__body">
                <h3 class="folio-item__title">VAT, credit &amp; risk suite</h3>
                <p class="folio-item__tag">Applications · ISO20022</p>
                <p class="folio-item__desc">VAT and invoice automation, commercial credit, Aani reconciliation, and risk tooling.</p>
                <span class="folio-item__more">Project details</span>
              </div>
            </a>
          </article>
          <article class="folio-item" data-category="lead">
            <a class="folio-item__link" href="#contact">
              <div class="folio-item__img folio-item__img--3"></div>
              <div class="folio-item__body">
                <h3 class="folio-item__title">Loan cash flow automation</h3>
                <p class="folio-item__tag">Excel VBA</p>
                <p class="folio-item__desc">VBA workflows for loan payment cash flow calculations and planning accuracy.</p>
                <span class="folio-item__more">Project details</span>
              </div>
            </a>
          </article>
          <article class="folio-item" data-category="dev">
            <a class="folio-item__link" href="#contact">
              <div class="folio-item__img folio-item__img--4" role="img" aria-label="Digital payment and instant transfer"></div>
              <div class="folio-item__body">
                <h3 class="folio-item__title">Instant payment — Fiji</h3>
                <p class="folio-item__tag">Bank of Baroda Fiji</p>
                <p class="folio-item__desc">Real-time interbank instant payment system for seamless transactions.</p>
                <span class="folio-item__more">Project details</span>
              </div>
            </a>
          </article>
        </div>
      </div>
    </section>

    <section class="s-focus section-pad">
      <div class="container">
        <h2 class="s-section__title s-section__title--center">Areas of impact.</h2>
        <div class="focus-grid">
          <blockquote class="focus-card">
            <p>“Led Finacle integration and BRF automation so regulatory reporting scales with the bank’s data.”</p>
          </blockquote>
          <blockquote class="focus-card">
            <p>“Delivered VAT, credit, and reconciliation systems aligned to ISO20022 and internal risk needs.”</p>
          </blockquote>
          <blockquote class="focus-card">
            <p>“Built instant payments for regional operations—real-time clearing between institutions.”</p>
          </blockquote>
        </div>
      </div>
    </section>

    <section class="s-numbers section-pad" id="numbers">
      <div class="container">
        <div class="numbers-grid">
          <div class="numbers-item">
            <p class="numbers-item__value"><span class="js-count" data-count="4">0</span>+</p>
            <h3 class="numbers-item__label">Years in delivery</h3>
            <p class="numbers-item__text">Software development and banking technology roles since 2022.</p>
          </div>
          <div class="numbers-item">
            <p class="numbers-item__value"><span class="js-count" data-count="6">0</span>+</p>
            <h3 class="numbers-item__label">Delivery areas</h3>
            <p class="numbers-item__text">Data, compliance, VAT, credit, reconciliation, and payments.</p>
          </div>
          <div class="numbers-item">
            <p class="numbers-item__value"><span class="js-count" data-count="2">0</span></p>
            <h3 class="numbers-item__label">Roles at Bornfire</h3>
            <p class="numbers-item__text">Progression from Software Developer to Tech Lead.</p>
          </div>
          <div class="numbers-item">
            <p class="numbers-item__value"><span class="js-count" data-count="2">0</span></p>
            <h3 class="numbers-item__label">Education milestones</h3>
            <p class="numbers-item__text">Higher secondary (2015) and B.E. ECE (2019).</p>
          </div>
        </div>
      </div>
    </section>

    <section class="s-edu section-pad" id="education" aria-labelledby="education-heading">
      <div class="container">
        <h2 class="s-section__title" id="education-heading">Education.</h2>
        <ul class="edu-list">
          <li>
            <span class="edu-list__dot" aria-hidden="true"></span>
            <span class="edu-list__year">2019</span>
            <div>
              <strong>A.R.J College of Engineering and Technology, Mannargudi</strong>
              <p>Bachelor of Engineering — Electronics and Communication Engineering</p>
            </div>
          </li>
          <li>
            <span class="edu-list__dot" aria-hidden="true"></span>
            <span class="edu-list__year">2015</span>
            <div>
              <strong>Laurel Higher Secondary School, Pattukkottai</strong>
              <p>Certificate of Higher Education</p>
            </div>
          </li>
          <li>
            <span class="edu-list__dot" aria-hidden="true"></span>
            <span class="edu-list__year">2022</span>
            <div>
              <strong>Core Java, J2EE</strong>
              <p>Accord Info Matrix — Jan 2022</p>
            </div>
          </li>
          <li>
            <span class="edu-list__dot" aria-hidden="true"></span>
            <span class="edu-list__year">2022</span>
            <div>
              <strong>HTML, JS, PHP, CSS, DOM, MySQL</strong>
              <p>Accord Info Matrix — Jan 2022</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <section class="s-contact section-pad" id="contact">
      <div class="container">
        <h2 class="s-section__title">Get In Touch.</h2>
        <p class="s-contact__lead">
          I’m available for opportunities where technical leadership and banking-domain delivery matter. Share your project or role and I’ll respond promptly.
        </p>
        <div class="s-contact__block">
          <div class="s-contact__group">
            <h3 class="s-contact__subtitle">Follow Me</h3>
            <ul class="s-contact__social">
              <li>
                <a class="s-contact__link s-contact__link--linkedin" href="https://www.linkedin.com/in/arangulavan-rajendran-101929211/" target="_blank" rel="noopener noreferrer">
                  <svg class="s-contact__icon" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  <span>LinkedIn</span>
                </a>
              </li>
            </ul>
          </div>
          <div class="s-contact__group">
            <h3 class="s-contact__subtitle">Contact Me</h3>
            <ul class="s-contact__details">
              <li><a href="mailto:arangulavanraj@gmail.com">arangulavanraj@gmail.com</a></li>
              <li><a href="tel:+971565758159">+971 56 575 8159</a></li>
              <li>Dubai (UAE)</li>
